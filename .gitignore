# Root secrets and local env
.env
.env.*
!.env.example

# Keep nested env files out of public repo
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Dependencies and build artifacts
**/node_modules/
**/dist/
**/.next/
**/out/
**/build/
**/coverage/

# Logs
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS and editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Runtime/temp
**/.temp/
**/.tmp/
**/*.pid
**/*.seed

# Cache
**/.cache/
**/.turbo/

# Container and deployment extras
**/.envrc
**/*.pem
**/*.key
**/*.crt
